# ===========================
# FourMeme Tools 环境变量配置
# ===========================
# 复制此文件为 .env 并填入真实值：cp .env.example .env

# --- Telegram 配置 ---
TG_API_ID=your_telegram_api_id
TG_API_HASH=your_telegram_api_hash
TG_PHONE_NUMBER=+8613800138000

# 推特监控群组 ID（Telegram 群组）
TWITTER_MONITOR_GROUP_ID=-100xxxxxxxxxx

# --- AI 分析配置（OpenAI 兼容 API）---
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://api.deepbricks.ai/v1/
AI_MODEL=GPT-5.1
# AI分析开关：true=启用 AI Meme分析，false=仅推文通知
ENABLE_AI_ANALYSIS=true

# --- 飞书通知配置 ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FEISHU_SIGN_SECRET=your_feishu_sign_secret

# --- BSC 链配置 ---
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
# 钱包私钥（用于创建代币，请妥善保管！）
WALLET_PRIVATE_KEY=0xyour_wallet_private_key
# 钱包地址
WALLET_ADDRESS=0xyour_wallet_address

# --- Four.meme 合约地址（默认无需修改）---
FOURMEME_TOKEN_MANAGER=0x5c952063c7fc8610FFDB798152D69F0B9550762b
FOURMEME_TOKEN_MANAGER_V2=0xec4549cadce5da21df6e6422d448034b5233bfbc

# --- 自动发币开关 ---
# 设为 true 时，检测到推文并分析出 meme 后将自动创建代币
# 设为 false 时，仅分析和通知，不自动创建
ENABLE_AUTO_CREATE=false

# 创建代币时的初始买入金额（BNB），默认 0.01
PRE_SALE_AMOUNT=0.01

# --- 捆绑发币：副钱包配置 ---
# 格式：私钥1:地址1,私钥2:地址2,...（多个钱包用逗号分隔）
# 发币后这些钱包会同时以 PRE_SALE_AMOUNT 买入代币
# 示例：BUNDLE_WALLETS=0xabc123...:0xWallet1,0xdef456...:0xWallet2
BUNDLE_WALLETS=

# 捆绑买入开关（true=启用捆绑买入，false=仅主钱包发币）
ENABLE_BUNDLE_BUY=false

# ========== MySQL 数据库配置 ==========
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=fourmeme_tools
